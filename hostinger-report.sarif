{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "originalUriBaseIds": {
        "%SRCROOT%": {
          "uri": "file:///"
        }
      },
      "tool": {
        "driver": {
          "name": "Kongali Security",
          "informationUri": "https://github.com/kongali1720/kongali-security",
          "version": "0.2.0",
          "rules": [
            {
              "id": "KONGALI-HIGH-0001",
              "name": "Missing security header: Content-Security-Policy",
              "shortDescription": {
                "text": "Missing security header: Content-Security-Policy"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the Content-Security-Policy security header."
              }
            },
            {
              "id": "KONGALI-HIGH-0002",
              "name": "Missing security header: Strict-Transport-Security",
              "shortDescription": {
                "text": "Missing security header: Strict-Transport-Security"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the Strict-Transport-Security security header."
              }
            },
            {
              "id": "KONGALI-HIGH-0003",
              "name": "Missing security header: X-Content-Type-Options",
              "shortDescription": {
                "text": "Missing security header: X-Content-Type-Options"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the X-Content-Type-Options security header."
              }
            },
            {
              "id": "KONGALI-HIGH-0004",
              "name": "Missing security header: X-Frame-Options",
              "shortDescription": {
                "text": "Missing security header: X-Frame-Options"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the X-Frame-Options security header."
              }
            },
            {
              "id": "KONGALI-MEDIUM-0005",
              "name": "Missing security header: Referrer-Policy",
              "shortDescription": {
                "text": "Missing security header: Referrer-Policy"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the Referrer-Policy security header."
              }
            },
            {
              "id": "KONGALI-MEDIUM-0006",
              "name": "Missing security header: Permissions-Policy",
              "shortDescription": {
                "text": "Missing security header: Permissions-Policy"
              },
              "fullDescription": {
                "text": "The HTTP response does not include the Permissions-Policy security header."
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "KONGALI-HIGH-0001",
          "level": "error",
          "message": {
            "text": "The HTTP response does not include the Content-Security-Policy security header."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "README.md",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "properties": {
            "severity": "HIGH",
            "category": "HTTP Security Headers",
            "owasp": "A05:2021",
            "cwe": "CWE-693",
            "impact": "Missing Content-Security-Policy may increase the risk of client-side injection and content execution attacks.",
            "remediation": "Implement a restrictive Content-Security-Policy appropriate for the application.",
            "evidence": {
              "header": "Content-Security-Policy",
              "status": "missing"
            }
          }
        },
        {
          "ruleId": "KONGALI-HIGH-0002",
          "level": "error",
